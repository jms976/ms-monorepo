// tsconfig.base.json
{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "Node",
    "baseUrl": ".",
    "outDir": "./dist",
    "paths": {
      "@common/ui": ["packages/ui/src"],
      "@common/utils": ["packages/utils/src"],
      "@common/styles": ["packages/styles/src"],
      "@common/types": ["packages/types/src"]
    }
  }
}
